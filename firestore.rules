rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Strict Full-Stack Backend Mediation:
    // All client-side direct writes and reads are blocked (allow read, write: if false).
    // All Firestore operations must be brokered securely through our Express backend
    // using the Firebase Admin SDK, ensuring complete access control, telegram identity
    // integrity verification, and state transition validation.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
